from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
import subprocess

app = FastAPI()

# Important: Allow your frontend domain to talk to this backend
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], 
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.post("/api/execute")
async def execute_code(payload: dict):
    code = payload.get("code")
    # WARNING: This is a conceptual example. 
    # NEVER run user-submitted code directly on your host machine.
    # Use a sandboxed environment like Docker.
    result = subprocess.run(["python3", "-c", code], capture_output=True, text=True)
    return {"result": result.stdout or result.stderr}

@app.post("/api/ai/correct")
async def ai_correct(payload: dict):
    # Logic to send code to an LLM (e.g., Gemini API)
    # Return the corrected code string
    return {"corrected_code": "print('Hello, World!')"}
